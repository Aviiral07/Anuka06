rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function needData() {
      return resource.data;
    }

    function requestNeedData() {
      return request.resource.data;
    }

    function isCreator() {
      return isSignedIn() && needData().createdBy == request.auth.uid;
    }

    function isHelper() {
      return isSignedIn() && needData().helperId == request.auth.uid;
    }

    function hasOnlyKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId)
        && hasOnlyKeys(
          request.resource.data,
          ['userId', 'name', 'createdAt']
        )
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80;
      allow update: if isSelf(userId)
        && hasOnlyKeys(
          request.resource.data,
          ['userId', 'name', 'createdAt']
        )
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80;
      allow delete: if false;
    }

    match /needs/{needId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && hasOnlyKeys(
          requestNeedData(),
          [
            'title',
            'description',
            'category',
            'location',
            'createdBy',
            'helperId',
            'status',
            'createdAt'
          ]
        )
        && requestNeedData().createdBy == request.auth.uid
        && requestNeedData().helperId == null
        && requestNeedData().status == 'open'
        && requestNeedData().title is string
        && requestNeedData().title.size() > 0
        && requestNeedData().title.size() <= 120
        && requestNeedData().description is string
        && requestNeedData().description.size() <= 500
        && requestNeedData().location is string
        && requestNeedData().location.size() > 0
        && requestNeedData().location.size() <= 120
        && requestNeedData().category in ['Food', 'Medical', 'Emergency'];

      allow update: if isSignedIn() && (
        canClaimNeed() || canCompleteNeed()
      );

      allow delete: if false;

      function canClaimNeed() {
        return needData().status == 'open'
          && needData().helperId == null
          && needData().createdBy != request.auth.uid
          && requestNeedData().diff(resource.data).changedKeys().hasOnly([
            'status',
            'helperId'
          ])
          && requestNeedData().status == 'helping'
          && requestNeedData().helperId == request.auth.uid;
      }

      function canCompleteNeed() {
        return needData().status == 'helping'
          && (isCreator() || isHelper())
          && requestNeedData().diff(resource.data).changedKeys().hasOnly([
            'status'
          ])
          && requestNeedData().status == 'completed';
      }
    }
  }
}

